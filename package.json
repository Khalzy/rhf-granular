{
  "name": "rhf-granular",
  "version": "0.2.5",
  "description": "Granular, selector-based subscriptions for React Hook Form",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test": "vitest",
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist"
  },
  "files": [
    "dist/index.cjs",
    "dist/index.mjs",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/useFormSelector.d.ts",
    "dist/useFormEffect.d.ts",
    "dist/useFormValue.d.ts"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "globals": "^17.3.0",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-hook-form": ">=7"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Khalzy/rhf-granular.git"
  },
  "keywords": [
    "react",
    "react-hook-form",
    "rhf",
    "performance",
    "re-render",
    "form-optimization",
    "selector",
    "subscription",
    "watch",
    "computed-values",
    "granular"
  ]
}
